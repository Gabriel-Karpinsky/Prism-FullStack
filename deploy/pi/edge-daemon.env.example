# Edge-daemon environment file.
#
# The daemon loads its full hardware config (motion envelope, GPIO pins, safety
# timings, LIDAR address) from PRISM_HARDWARE_CONFIG. This env file only holds
# the path to that JSON file plus anything you want to override for a one-off
# test run without editing the persistent config.

PRISM_HARDWARE_CONFIG=/etc/prism-scanner/hardware.json
