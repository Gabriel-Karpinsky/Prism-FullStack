EDGE_BIND_HOST=127.0.0.1
EDGE_BIND_PORT=9090
EDGE_SERIAL_PORT=/dev/ttyACM0
EDGE_SERIAL_BAUD=115200
EDGE_ENABLE_SERIAL=true
EDGE_USE_SIMULATION=false
EDGE_USE_MOCK_LIDAR=false
EDGE_GRID_WIDTH=48
EDGE_GRID_HEIGHT=24
EDGE_LIDAR_BUS=1
EDGE_LIDAR_ADDRESS=98
EDGE_TICK_INTERVAL_MS=20
EDGE_STATUS_POLL_INTERVAL_MS=100
EDGE_HEARTBEAT_INTERVAL_MS=400
EDGE_COMMAND_TIMEOUT_MS=900
EDGE_MOVE_SETTLE_MS=80
EDGE_ESTIMATED_POINT_TIME_MS=120
