[Unit]
Description=Cliff Scanner Edge Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
SupplementaryGroups=dialout i2c
EnvironmentFile=-/etc/cliffscanner/edge-daemon.env
WorkingDirectory=/opt/cliffscanner
ExecStart=/opt/cliffscanner/bin/cliffscanner-edge
Restart=always
RestartSec=2
NoNewPrivileges=true
ProtectSystem=full
ReadWritePaths=/var/lib/cliffscanner

[Install]
WantedBy=multi-user.target
